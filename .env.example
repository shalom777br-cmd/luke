# GEMINI_API_KEY: Required for Gemini AI API calls. Set this in the Secrets panel of AI Studio settings.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted. Automatically injected by AI Studio.
APP_URL=

# Supabase URL for connection
SUPABASE_URL=

# Supabase Anon Public Key
SUPABASE_ANON_KEY=

# Supabase Service Role Secret Key (Recommended for server-side operations)
SUPABASE_SERVICE_ROLE_KEY=

# Timothy Security Token (Used to secure dev task log API endpoints)
TIMOTHY_SECURITY_TOKEN=temote-secure-xk92mQ7pL4vNu
VITE_TIMOTHY_SECURITY_TOKEN=temote-secure-xk92mQ7pL4vNu

